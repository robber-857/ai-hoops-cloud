{
  "templateId": "high_knees_in_place_side",
  "mode": "training",
  "camera": "side",
  "displayName": "高抬腿｜原地高抬腿(侧面)",
  "categoryWeights": { "posture": 0.3, "execution": 0.5, "consistency": 0.2 },
  "options": { "targetDurationSec": 20 },
  "metrics": [
    {
      "metricId": "P_torso_upright",
      "category": "posture",
      "weight": 0.50,
      "type": "target",
      "computeKey": "torsoLeanDegSide",
      "params": { "target": 0, "tol": 12, "margin": 20 },
      "hint_bad": "上身前后晃动：保持躯干直立，不要为了抬腿而弯腰驼背。"
    },
    {
      "metricId": "P_landing_position",
      "category": "posture",
      "weight": 0.50,
      "type": "range",
      "computeKey": "footStrikeOffsetXUnderHip",
      "params": { "L": -0.1, "U": 0.10, "margin": 0.20 },
      "hint_bad": "落脚点偏移：尝试将脚落在臀部正下方，避免向前踢腿。"
    },
    {
      "metricId": "E_knee_height",
      "category": "execution",
      "weight": 0.60,
      "type": "target",
      "computeKey": "kneeToHipHeightRatioSide",
      "params": { "target": 1.00, "tol": 0.20, "margin": 0.35 },
      "hint_bad": "抬腿高度不够：膝盖要抬到接近髋部的高度（大腿平行地面）。"
    },
    {
      "metricId": "E_cadence",
      "category": "execution",
      "weight": 0.40,
      "type": "target",
      "computeKey": "cadenceSPM",
      "params": { "target": 160, "tol": 30, "margin": 50 },
      "hint_bad": "频率太慢：在保证高度的前提下，加快换腿频率。"
    },
    {
      "metricId": "C_height_consistency",
      "category": "consistency",
      "weight": 0.50,
      "type": "target",
      "computeKey": "stdKneeToHipHeightRatioSide",
      "params": { "target": 0.30, "tol": 0.1, "margin": 0.15 },
      "hint_bad": "高度不稳定：体力下降时也要咬牙保持每一次抬腿的高度。"
    },
    {
      "metricId": "C_rhythm_stability",
      "category": "consistency",
      "weight": 0.50,
      "type": "target",
      "computeKey": "stepIntervalCV",
      "params": { "target": 0.2, "tol": 0.1, "margin": 0.17 },
      "hint_bad": "节奏有点不稳：保持像节拍器一样稳定的跑步节奏。"
    }
  ]
}