{
  "templateId": "dribble_front_onehand_v",
  "mode": "dribbling",
  "camera": "front",
  "displayName": "正面｜单手 V 运球(接球落点：按四等分)",
  "categoryWeights": { "posture": 1.0, "execution": 1.0, "consistency": 1.0 },
  "options": { "handedness": "auto" },
  "rulesNote": "左手模板：接球点更偏右侧(3-4份)；右手模板：接球点更偏左侧(1-2份)。",
  "metrics": [
    {
      "metricId": "P_toe_forward_L",
      "category": "posture",
      "weight": 0.50,
      "type": "target",
      "computeKey": "toeAngleDegLeft",
      "params": { "target": 5, "tol": 12, "margin": 12},
      "hint_bad": "Point your left toes forward as much as possible for a more stable stance."
    },
    {
      "metricId": "P_toe_forward_R",
      "category": "posture",
      "weight": 0.50,
      "type": "target",
      "computeKey": "toeAngleDegRight",
      "params": { "target": 5, "tol": 12, "margin": 12 },
      "hint_bad": "Point your right toes forward as much as possible to enhance stability"
    },

    {
      "metricId": "E_wrist_align_over_opposite_foot",
      "category": "execution",
      "weight": 0.45,
      "type": "target",
      "computeKey": "wristAlignOppFootAtPeak",
      "params": { "target": 0.0, "tol": 0.08, "margin": 0.175 },
      "hint_bad": "When dribbling to the other side, the dribbling hand is not in position: the wrist should be near the top of the opposite foot."
    },
    {
      "metricId": "E_receive_zone_quarters",
      "category": "execution",
      "weight": 0.55,
      "type": "range",
      "computeKey": "receiveZoneQuarterNorm",
      "params": {"L": 0.35,"U": 0.65,"margin": 0.05},
      "hint_bad":"Try to catch the ball directly in front of your body, making the landing point as close to the center as possible, and maintaining a stable landing point."
    },

    {
      "metricId": "C_receive_point_consistency",
      "category": "consistency",
      "weight": 1.0,
      "type": "target",
      "computeKey": "stdWristXAtContactPerCycleNormByST",
      "params": { "target": 0.08, "tol": 0.045, "margin": 0.13 },
      "hint_bad": "The ball's landing point is inconsistent when dribbling: First, slow down to fix the landing point, then increase speed and intensity."
    },
    {
      "metricId": "C_height_consistency",
      "category": "consistency",
      "weight": 0.50,
      "type": "target",
      "computeKey": "stdWristHeightRatioToHipPerCycle",
      "params": { "target": 0.042, "tol": 0.03, "margin": 0.052 },
      "hint_bad": "Unstable dribbling height: Maintain rhythm and avoid unstable dribbling height."
   }
  ]
}
