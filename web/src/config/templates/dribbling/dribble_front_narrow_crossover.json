{
  "templateId": "dribble_front_narrow_crossover",
  "mode": "dribbling",
  "camera": "front",
  "displayName": "正面｜窄距 Crossover",
  "categoryWeights": { "posture": 1.0, "execution": 1.0, "consistency": 1.0 },
  "options": { "handedness": "auto" },
  "metrics": [
    {
      "metricId": "P_toe_forward_L",
      "category": "posture",
      "weight": 0.20,
      "type": "target",
      "computeKey": "toeAngleDegLeft",
      "params": { "target": 0, "tol": 13, "margin": 10 },
      "hint_bad": "Point your left toes forward as much as possible for a more stable stance."
    },
    {
      "metricId": "P_toe_forward_R",
      "category": "posture",
      "weight": 0.20,
      "type": "target",
      "computeKey": "toeAngleDegRight",
      "params": { "target": 0, "tol": 13, "margin": 10 },
      "hint_bad": "Point your right toes forward as much as possible to enhance stability."
    },
    {
      "metricId": "P_shoulder_stance_ratio",
      "category": "posture",
      "weight": 0.60,
      "type": "target",
      "computeKey": "shoulderStanceRatio",
      "params": { "target": 2.0, "tol": 0.43, "margin": 0.37 },
      "hint_bad": "Make sure you have a good distance between your feet; the ratio of your stance distance to your shoulder width should be between 1.55 and 2.45."
    },

    {
      "metricId": "E_cross_midline_rate",
      "category": "execution",
      "weight": 0.60,
      "type": "range",
      "computeKey": "crossMidlineRate",
      "params": { "L": 0.62, "U": 1.00, "margin": 0.20 },
      "hint_bad": "The crossing of the center line is not obvious: the ball needs to cut across the body's center line."
    },
    {
      "metricId": "E_overreach_control",
      "category": "execution",
      "weight": 0.40,
      "type": "range",
      "computeKey": "overreachControlFront",
      "params": { "L": 0.05, "U": 0.24, "margin": 0.25 },
      "hint_bad": "Excessive swing: The ball is prone to drifting when controlled; it may cross the center line, but avoid overextending."
    },

    {
      "metricId": "C_receive_x_consistency",
      "category": "consistency",
      "weight": 0.5,
      "type": "target",
      "computeKey": "stdWristXAtContactPerCycleNormByST",
      "params": { "target": 0.06, "tol": 0.03, "margin": 0.08 },
      "hint_bad": "Unstable ball landing point: Ensure wrist stability while dribbling. Practice slow, consistent ball landing points first, then increase speed."
    },
    {
      "metricId": "C_height_consistency",
      "category": "consistency",
      "weight": 0.50,
      "type": "target",
      "computeKey": "stdWristHeightRatioToHipPerCycle",
      "params": { "target": 0.042, "tol": 0.03, "margin": 0.052 },
      "hint_bad": "Highly unstable: Maintain a steady rhythm and avoid sudden spikes and dips."
   }
  ]
