{
  "templateId": "dribble_side_onehand_oneside",
  "mode": "dribbling",
  "camera": "side",
  "displayName": "侧面｜单手单侧运球(落点在脚尖前方一点)",
  "categoryWeights": { "posture": 0.4, "execution": 0.4, "consistency": 0.2 },
  "options": { "handedness": "auto" },
  "metrics": [
    {
      "metricId": "P_knee_over_toe",
      "category": "posture",
      "weight": 0.25,
      "type": "range",
      "computeKey": "kneeOverToeSide",
      "params": { 
        "L": -0.15, 
        "U": -0.05, 
        "margin": 0.15 
      },
      "hint_bad": "Knees leaning forward too much: If your center of gravity is too far forward, you are likely to lose your balance. Try sitting back with your hips."
    },
    {
      "metricId": "P_hip_position",
      "category": "posture",
      "weight": 0.20,
      "type": "range",
      "computeKey": "hipForwardRatioSide",
      "params": { 
        "L": -0.30, 
        "U": -0.14, 
        "margin": 0.22 
      },
      "hint_bad": "Hip thrust forward: Do not stick out your stomach, maintain a flexed hip posture, and place your weight on the middle and back of your feet."
    },
    {
      "metricId": "P_trunk_lean",
      "category": "posture",
      "weight": 0.30,
      "type": "target",
      "computeKey": "trunkLeanDegSide",
      "params": { "target": 25, "tol": 10, "margin": 15 },
      "hint_bad": "Poor forward tilt angle: Maintain a forward tilt of 15°–35° to both protect the ball and allow for immediate start."
    },
    {
      "metricId": "P_hand_reach_control",
      "category": "posture",
      "weight": 0.25,
      "type": "range",
      "computeKey": "handForwardOffsetSide",
      "params": { "L": 0.12, "U": 0.40, "margin": 0.20 },
      "hint_bad": "Reaching too far: Keep the dribbling point close to the side and in front of your body, and do not overextend your arms."
    },

    {
      "metricId": "E_dribble_spot_x",
      "category": "execution",
      "weight": 0.70,
      "type": "target",
      "computeKey": "wristToToeForwardOffsetSide",
      "params": { 
        "target": 0.28, 
        "tol": 0.15, 
        "margin": 0.22 
      },
      "hint_bad": "Landing point: The ball should land approximately 1-2 ball lengths in front of your toes."
    },
    {
      "metricId": "E_dribble_height",
      "category": "execution",
      "weight": 0.30,
      "type": "range",
      "computeKey": "wristHeightRatioToHip",
      "params": { "L": 0.40, "U": 0.68, "margin": 0.32 },
      "hint_bad": "Dribbling height: Control it between the knee and hip; too high or too low will affect speed."
    },

    {
      "metricId": "C_spot_consistency",
      "category": "consistency",
      "weight": 0.60,
      "type": "target",
      "computeKey": "stdWristToToeForwardOffsetPerCycle",
      "params": { "target": 0.05, "tol": 0.04, "margin": 0.08 },
      "hint_bad": "Forward and backward landing point drift: When dribbling in a fixed position, the ball's landing point should be fixed like a pile driver."
    },
    {
      "metricId": "C_height_consistency",
      "category": "consistency",
      "weight": 0.40,
      "type": "target",
      "computeKey": "stdWristHeightRatioToHipPerCycle",
      "params": { "target": 0.04, "tol": 0.025, "margin": 0.052 },
      "hint_bad": "Unstable dribbling height: Maintain a rhythm and avoid erratic dribbling height."
    }
  ]
}