{
  "templateId": "dribble_front_onehand_oneside_height",
  "mode": "dribbling",
  "camera": "front",
  "displayName": "正面｜单手单侧运球(hip_high)",
  "categoryWeights": { "posture": 1.0, "execution": 1.0, "consistency": 1.0 },
  "options": { "handedness": "auto", "heightLevel": "hip_high" },
  "metrics": [
    {
      "metricId": "P_stance_ratio",
      "category": "posture",
      "weight": 0.6,
      "type": "range",
      "computeKey": "shoulderStanceRatio",
      "params": { "L": 1.75, "U": 2.2, "margin": 0.50 },
      "hint_bad": "Make sure you have a good distance between your feet; the ratio of your stance distance to your shoulder width should be between 1.55 and 2.45."
    },
    {
      "metricId": "P_guide_hand_chest_box",
      "category": "posture",
      "weight": 0.4,
      "type": "range",
      "computeKey": "guideHandInChestBoxRate",
      "params": { "L": 0.75, "U": 1.00, "margin": 0.40 },
      "hint_bad": "The non-dribbling hand is not always placed in front of the chest: Keeping the non-dribbling elbow to wrist in front of the chest increases ball protection efficiency."
    },

    {
      "metricId": "E_height_target_hip_only",
      "category": "execution",
      "weight": 1.0,
      "type": "rangeByOption",
      "computeKey": "wristHeightRatioToShoulder",
      "params": {
        "optionKey": "heightLevel",
        "ranges": {
          "hip_high": { "L": 0.45, "U": 0.75, "margin": 0.52 }
        }
      },
      "hint_bad": "Maintain dribbling height within the hip target range: first, dribble slowly and steadily near the hip, then gradually increase speed."
    },

    {
      "metricId": "C_height_consistency",
      "category": "consistency",
      "weight": 1.0,
      "type": "target",
      "computeKey": "stdWristHeightRatioToShoulderPerCycle",
      "params": { "target": 0.05, "tol": 0.012, "margin": 0.02 },
      "hint_bad": "Large fluctuations in dribbling height: First, stabilize the height slowly, then gradually increase the speed."
    }
  ]
}
