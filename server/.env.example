APP_NAME=AI Hoops Cloud API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Local development can keep using the split POSTGRES_* values below.
# Production on Render can set DATABASE_URL instead.
DATABASE_URL=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_hoops
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-another-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_COOKIE_NAME=ai-hoops-session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=

VERIFICATION_CODE_EXPIRE_SECONDS=300
VERIFICATION_CODE_RESEND_COOLDOWN_SECONDS=60
VERIFICATION_CODE_MAX_ATTEMPTS=5

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=eltonw482@gmail.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=eltonw482@gmail.com
SMTP_FROM_NAME=AI Hoops Cloud
SMTP_STARTTLS=true

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3001","http://127.0.0.1:3001"]
